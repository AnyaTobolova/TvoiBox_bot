# Безопасный пример dev-контура mini app на VPS.
# Этот файл нужен как шаблон для внешней проверки mini app без влияния на production-ветку `main`
# и без конфликта с уже работающим production-стеком на сервере.

STACK_NAME=tvoy-box-miniapp-dev

NODE_ENV=production
TZ=Europe/Moscow

APP_NAME=tvoy-box-miniapp-dev
APP_HOST=0.0.0.0
APP_PORT=3000
API_LOG_LEVEL=info

API_BIND_IP=127.0.0.1
API_PORT=3310
MINI_APP_BIND_IP=127.0.0.1
MINI_APP_PORT=3312
API_BASE_URL=http://api:3000

# Для безопасного dev-контура нужны отдельные dev-поддомены.
PUBLIC_API_DOMAIN=api-dev.example.ru
PUBLIC_APP_DOMAIN=app-dev.example.ru
NEXT_PUBLIC_API_BASE_URL=https://api-dev.example.ru
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true
MINI_APP_ALLOWED_ORIGINS=https://app-dev.example.ru
MINI_APP_ENABLE_DEV_LOGIN=true

# Безопасный путь: не использовать production-бота для dev-проверки mini app.
# Рекомендуется отдельный тестовый бот и отдельный токен.
BOT_LOG_LEVEL=info
BOT_DRY_RUN=false
BOT_DELIVERY_MODE=webhook
BOT_BIND_IP=127.0.0.1
BOT_PORT=3311
BOT_WEBHOOK_HOST=0.0.0.0
BOT_WEBHOOK_PORT=8081
BOT_WEBHOOK_PATH=/telegram/webhook/tvoy-box-miniapp-dev
BOT_WEBHOOK_PUBLIC_URL=https://api-dev.example.ru/telegram/webhook/tvoy-box-miniapp-dev
BOT_WEBHOOK_SECRET_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_DEV_WEBHOOK_SECRET

ADMIN_TELEGRAM_ID=PUT_ADMIN_TELEGRAM_ID_HERE
TRAINER_TELEGRAM_ID=PUT_TRAINER_TELEGRAM_ID_HERE
TELEGRAM_BOT_TOKEN=PUT_DEV_BOT_TOKEN_HERE
MINI_APP_AUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_DEV_MINI_APP_SECRET

POSTGRES_DB=tvoy_box_dev
POSTGRES_USER=tvoy_box_dev
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_DEV_PASSWORD
DATABASE_URL=postgresql://tvoy_box_dev:CHANGE_ME_TO_A_LONG_RANDOM_DEV_PASSWORD@postgres:5432/tvoy_box_dev

GOOGLE_CALENDAR_SYNC_MODE=real
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_JSON_SOURCE=../.secrets/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/run/secrets/google-service-account.json

# Optional fallback if you do not use a JSON file.
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@example.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\\nreplace-me\\n-----END PRIVATE KEY-----\\n
